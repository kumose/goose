typedef struct _goose_aggregate_state {
	void *internal_ptr;
} * goose_aggregate_state;

//! A function to return the aggregate state's size.
typedef idx_t (*goose_aggregate_state_size)(goose_function_info info);

//! A function to initialize an aggregate state.
typedef void (*goose_aggregate_init_t)(goose_function_info info, goose_aggregate_state state);

//! An optional function to destroy an aggregate state.
typedef void (*goose_aggregate_destroy_t)(goose_aggregate_state *states, idx_t count);

//! A function to update a set of aggregate states with new values.
typedef void (*goose_aggregate_update_t)(goose_function_info info, goose_data_chunk input,
                                          goose_aggregate_state *states);

//! A function to combine aggregate states.
typedef void (*goose_aggregate_combine_t)(goose_function_info info, goose_aggregate_state *source,
                                           goose_aggregate_state *target, idx_t count);

//! A function to finalize aggregate states into a result vector.
typedef void (*goose_aggregate_finalize_t)(goose_function_info info, goose_aggregate_state *source,
                                            goose_vector result, idx_t count, idx_t offset);

