# name: tests/scripts/sql/function/string/like_unicode.test
# description: Test _ and like unicode characters
# group: [string]

statement ok
PRAGMA enable_verification

statement ok
CREATE TABLE t0 (c0 VARCHAR);

statement ok
INSERT INTO t0 VALUES ('票'),('t'),('%'),('丑'),('多'), ('🦆');

query I
SELECT count(*) FROM t0 WHERE t0.c0 LIKE '_';
----
6

query I
SELECT count(*) FROM t0 WHERE t0.c0 ILIKE '_';
----
6

query I
SELECT '🦆a🦆' LIKE '_a_'
----
true

query I
SELECT '🦆a🦆' ILIKE '_A_'
----
true

query I
SELECT 'BaB' ILIKE '_A_'
----
true

query I
SELECT '🦆🦆' ILIKE '_'
----
false

query I
SELECT '🦆🦆' ILIKE '__'
----
true

query I
SELECT '🦆🦆' ILIKE '___'
----
false
