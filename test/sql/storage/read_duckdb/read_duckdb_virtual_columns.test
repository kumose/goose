# name: test/sql/storage/read_goose/read_goose_virtual_columns.test
# description: Test basic usage of read_goose
# group: [read_goose]

foreach dbindex 1 2

statement ok
ATTACH '__TEST_DIR__/read_goose_virt${dbindex}.db' AS rd

statement ok
CREATE TABLE rd.my_tbl AS SELECT 42 + i AS v FROM range(0, ${dbindex}) t(i)

statement ok
DETACH rd

endloop

query III
SELECT rowid, (filename.replace('\', '/').split('/'))[3], * FROM read_goose('__TEST_DIR__/read_goose_virt[1-2].db') ORDER BY filename, rowid
