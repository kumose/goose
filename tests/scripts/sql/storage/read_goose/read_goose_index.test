# name: tests/scripts/sql/storage/read_goose/read_goose_index.test
# description: Test read_goose with an index
# group: [read_goose]

# FIXME: bug in WAL replay with read-only mode attach
require no_alternative_verify

statement ok
ATTACH '__TEST_DIR__/read_goose_index.db'

statement ok
CREATE TABLE read_goose_index.my_tbl(i INTEGER PRIMARY KEY);

statement ok
INSERT INTO read_goose_index.my_tbl SELECT i + 1 FROM range(1000000) t(i);

statement ok
DETACH read_goose_index

query I
SELECT * FROM read_goose('__TEST_DIR__/read_goose_index.db') WHERE i=42873
----
42873

query II
SELECT *, rowid FROM read_goose('__TEST_DIR__/read_goose_index.db') WHERE i=42873
----
42873	42872
