# name: test/extension/test_tags.test
# description: Test querying tagged extension items.
# group: [extension]

require skip_reload

require notmingw

require allow_unsigned_extensions

statement ok
PRAGMA enable_verification

statement ok
LOAD '__BUILD_DIRECTORY__/test/extension/loadable_extension_demo.goose_extension';

query II
SELECT function_name, tags['ext:author'] FROM goose_functions() WHERE tags['ext:name'] = 'loadable_extension_demo' ORDER BY function_name;
----
add_point	Goose Labs
sub_point	Goose Labs

query II
SELECT type_name, tags['ext:author'] FROM goose_types() WHERE tags['ext:name'] = 'loadable_extension_demo' ORDER BY type_name;
----
POINT	Goose Labs