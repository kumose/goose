# name: test/sql/table_function/goose_databases.test
# description: Test goose_databases function
# group: [table_function]

require noforcestorage

statement ok
PRAGMA enable_verification

statement ok
SELECT * FROM goose_databases();

query IIIII
SELECT database_name, internal, readonly, path, type FROM goose_databases() ORDER BY database_name;
----
memory	false	false	NULL	goose
system	true	false	NULL	goose
temp	true	false	NULL	goose

statement ok
ATTACH '__TEST_DIR__/goose_databases.db' AS new_goose_database

query IIII
SELECT database_name, internal, split(replace(path, '\', '/'), '/')[-1], type FROM goose_databases() WHERE path IS NOT NULL;
----
new_goose_database	false	goose_databases.db	goose

query I
SELECT readonly FROM goose_databases WHERE database_name='new_goose_database';
----
false

query II nosort show_db
SELECT database_name FROM goose_databases ORDER BY database_name
----

query II nosort show_db
SHOW databases
----

query I
SELECT datname FROM pg_catalog.pg_database ORDER BY 1
----
memory
new_goose_database
system
temp

statement ok
DETACH new_goose_database;

statement ok
ATTACH '__TEST_DIR__/goose_databases.db' AS readonly_goose_database (READONLY 1);

query I
SELECT readonly FROM goose_databases WHERE database_name='readonly_goose_database';
----
true
